        "from sklearn.feature_extraction.text import TfidfVectorizer\n",
        "\n",
        "results = []\n",
        "\n",
        "# TF-IDF word\n",
        "tfidf_w = TfidfVectorizer(max_features=2000, ngram_range=(1,2), min_df=2)\n",
        "X_tfidf_w = tfidf_w.fit_transform(texts)\n",
        "res_tfidf_w = eval_representation(X_tfidf_w, labels, 'TFIDF_word')\n",
        "results.append(res_tfidf_w)\n",
        "print(res_tfidf_w)\n",
        "\n",
        "# TF-IDF char\n",
        "tfidf_c = TfidfVectorizer(analyzer='char', ngram_range=(3,5), min_df=2, max_features=2000)\n",
        "X_tfidf_c = tfidf_c.fit_transform(texts)\n",
        "res_tfidf_c = eval_representation(X_tfidf_c, labels, 'TFIDF_char')\n",
        "results.append(res_tfidf_c)\n",
        "print(res_tfidf_c)\n",
        "\n",
        "# Wizualizacje na TF-IDF word\n",
