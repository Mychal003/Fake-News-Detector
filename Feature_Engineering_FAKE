        "def eval_representation(X, y, name, n_splits=5):\n",
        "    skf = StratifiedKFold(n_splits=n_splits, shuffle=True, random_state=RANDOM_STATE)\n",
        "    f1s, accs = [], []\n",
        "    for tr, te in skf.split(np.zeros(len(y)), y):\n",
        "        X_tr = X[tr] if hasattr(X, 'tocsr') else X[tr, :]\n",
        "        X_te = X[te] if hasattr(X, 'tocsr') else X[te, :]\n",
        "        y_tr, y_te = y[tr], y[te]\n",
        "\n",
        "        # Standaryzacja dla gęstych\n",
        "        if not hasattr(X_tr, 'tocsr'):\n",
        "            scaler = StandardScaler(with_mean=False)\n",
        "            X_tr = scaler.fit_transform(X_tr)\n",
        "            X_te = scaler.transform(X_te)\n",
        "\n",
        "        clf = LogisticRegression(max_iter=2000)\n",
        "        clf.fit(X_tr, y_tr)\n",
        "        preds = clf.predict(X_te)\n",
        "        accs.append(accuracy_score(y_te, preds))\n",
        "        f1s.append(f1_score(y_te, preds, average='macro'))\n",
        "    return { 'rep': name,\n",
        "             'f1_macro_mean': float(np.mean(f1s)), 'f1_macro_std': float(np.std(f1s)),\n",
        "             'acc_mean': float(np.mean(accs)), 'acc_std': float(np.std(accs)) }\n",
        "\n",
        "def plot_2d_dense(X_dense, y, title, out_file, method='pca', max_n=3000):\n",
        "    n = X_dense.shape[0]\n",
        "    if n > max_n:\n",
        "        idx = np.random.RandomState(42).choice(n, size=max_n, replace=False)\n",
        "        X_plot, y_plot = X_dense[idx], y[idx]\n",
        "    else:\n",
        "        X_plot, y_plot = X_dense, y\n",
        "    if method == 'pca':\n",
        "        reducer = PCA(n_components=2, random_state=42)\n",
        "        XY = reducer.fit_transform(X_plot)\n",
        "    else:\n",
        "        reducer = TSNE(n_components=2, init='pca', random_state=42, learning_rate='auto', perplexity=30)\n",
        "        XY = reducer.fit_transform(X_plot)\n",
        "    plt.figure(figsize=(7,6))\n",
        "    classes = np.unique(y_plot)\n",
        "    for c in classes:\n",
        "        m = (y_plot == c)\n",
        "        plt.scatter(XY[m,0], XY[m,1], s=10, alpha=0.7, label=str(c))\n",
        "    plt.title(title)\n",
        "    plt.legend(loc='best', markerscale=2)\n",
        "    plt.tight_layout()\n",
        "    plt.savefig(out_file, dpi=160)\n",
        "    plt.show()"
      ]
